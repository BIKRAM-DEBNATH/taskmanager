# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/teamtaskmanager
# Atlas (replace with your connection string):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/teamtaskmanager?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────
# Use a long random string — NEVER commit the real value
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Local dev:
CLIENT_URL=http://localhost:5173
# Production example (add your real domain):
# CLIENT_URL=https://your-frontend.vercel.app,https://your-custom-domain.com
